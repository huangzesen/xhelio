    },
    {
      "import_path": "pfsspy",
      "sandbox_alias": "pfsspy",
      "required": false,
      "description": "Potential Field Source Surface (PFSS) modeling package for solar physics. Used to compute coronal magnetic field solutions from magnetogram data. Essential for tracing solar wind flux roots and understanding the heliospheric magnetic field topology.",
      "catalog_submodules": []
    },
    {
      "import_path": "astroquery",
      "sandbox_alias": "astroquery",
      "required": false,
      "description": "Python package for querying astronomical databases (SIMBAD, VizieR, NED, etc.)",
