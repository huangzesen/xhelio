    },
    {
      "import_path": "sunkit_magex",
      "sandbox_alias": "magex",
      "required": false,
      "description": "Modern SunPy-affiliated package for coronal magnetic field extrapolation (PFSS, NLFF). Provides tools for modeling magnetic fields from photospheric magnetograms.",
      "catalog_submodules": []
    },
    {
      "import_path": "lxml",
      "sandbox_alias": "lxml",
      "required": false,
      "description": "Install lxml package for XML parsing in SunPy",
      "catalog_submodules": []
    },
    {
      "import_path": "zeep",
