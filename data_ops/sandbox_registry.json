{
  "version": 1,
  "packages": [
    {
      "import_path": "scipy",
      "sandbox_alias": "scipy",
      "required": true,
      "description": "Scientific computing (signal, FFT, interpolation, stats, integration)",
      "catalog_submodules": [
        "scipy.signal",
        "scipy.fft",
        "scipy.interpolate",
        "scipy.stats",
        "scipy.integrate"
      ]
    },
    {
      "import_path": "pywt",
      "sandbox_alias": "pywt",
